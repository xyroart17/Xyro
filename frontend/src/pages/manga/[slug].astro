---
export const prerender = true;
import { ClientRouter } from 'astro:transitions';
import '../../styles/global.css';
import MangaReader from '../../components/MangaReader.astro';

export async function getStaticPaths() {
    const { client } = await import('../../utils/sanity.js');
    const mangaList = await client.fetch(`*[_type == "manga" && featured == true] | order(order asc) {
        title,
        slug,
        subtitle,
        coverImage,
        genre,
        status,
        tag,
        socialLinks,
        "pages": pages[].asset->url,
        "pageCount": count(pages),
        "wip": wip[].asset->url
    }`);

    const isOnlyManga = mangaList.length === 1;

    return mangaList.map((manga: any, index: number) => {
        const nextManga = index < mangaList.length - 1 ? {
            title: mangaList[index + 1].title,
            slug: mangaList[index + 1].slug
        } : null;
        return {
            params: { slug: manga.slug.current },
            props: { manga, nextManga, isOnlyManga }
        };
    });
}

interface Props {
    manga: any;
    nextManga: any;
    isOnlyManga: boolean;
}

const { manga, nextManga, isOnlyManga } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>{manga.title} — Xyro</title>

    <ClientRouter />

    {/* --- SEO & OPEN GRAPH METADATA --- */}
    <meta name="description" content={manga.subtitle || `Read ${manga.title} online at Xyro.`} />
    <meta property="og:title" content={`${manga.title} — Xyro`} />
    <meta property="og:description" content={manga.subtitle || `Read ${manga.title} online at Xyro.`} />
    <meta property="og:type" content="article" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=1">
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png?v=1">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=1">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=1">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=1">
    <link rel="shortcut icon" href="/favicon.ico?v=1">
    <link rel="manifest" href="/site.webmanifest?v=1">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <MangaReader manga={manga} nextManga={nextManga} isOnlyManga={isOnlyManga} />
</body>
</html>
