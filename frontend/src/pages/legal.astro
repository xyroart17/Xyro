---
export const prerender = true;
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import "../styles/legal.css";
import LegalNavigation from "../components/LegalNavigation.astro";
import LegalSection from "../components/LegalSection.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Legal Center — Xyro</title>
        <meta
            name="description"
            content="Privacy Policy, Terms of Service, and Commission Guide for Xyro. Everything you need to know before working with me."
        />
        <link rel="canonical" href="https://xyro.art/legal" />
        <meta property="og:title" content="Legal Center — Xyro" />
        <meta
            property="og:description"
            content="Privacy Policy, Terms of Service, and Commission Guide for Xyro."
        />
        <meta property="og:type" content="website" />
        <meta name="twitter:card" content="summary" />

        <ClientRouter />

        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/apple-touch-icon.png?v=1"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="48x48"
            href="/favicon-48x48.png?v=1"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href="/favicon-32x32.png?v=1"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="16x16"
            href="/favicon-16x16.png?v=1"
        />
        <link
            rel="icon"
            type="image/svg+xml"
            href="/favicon.svg?v=1"
        />
        <link rel="shortcut icon" href="/favicon.ico?v=1" />
        <link rel="manifest" href="/site.webmanifest?v=1" />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link
            href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700;9..40,800&family=Syne:wght@400;500;600;700;800&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <Navbar />

        <!-- LEGAL PAGE -->
        <main class="legal-page">
            <!-- HEADER -->
            <header class="legal-header">
                <a href="/" id="legalBackLink" class="legal-back-link">
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="M19 12H5"></path>
                        <path d="M12 19l-7-7 7-7"></path>
                    </svg>
                    Back to Home
                </a>
                <h1 class="legal-header-title">Legal Center</h1>
                <p class="legal-header-subtitle">
                    Everything you need to know before working with Xyro.
                </p>
                <nav class="legal-quick-nav" aria-label="Jump to section">
                    <a href="#privacy">Privacy Policy</a>
                    <a href="#terms">Terms of Service</a>
                    <a href="#commissions">Commission Guide</a>
                </nav>
            </header>

            <!-- MOBILE STICKY NAV -->
            <div
                class="legal-mobile-nav"
                role="navigation"
                aria-label="Legal page sections"
            >
                <div class="legal-mobile-nav-inner">
                    <a href="#privacy">Privacy</a>
                    <a href="#terms">Terms</a>
                    <a href="#commissions">Commission Guide</a>
                </div>
            </div>

            <!-- CONTENT LAYOUT -->
            <div class="legal-layout">
                <!-- Sidebar (desktop only) -->
                <LegalNavigation />

                <!-- Main Content -->
                <div class="legal-content">
                    <!-- ============================================== -->
                    <!-- PRIVACY POLICY                                 -->
                    <!-- ============================================== -->
                    <LegalSection id="privacy" title="Privacy Policy">
                        <p>
                            Xyro ("I," "me," or "my") operates the
                            Xyro website and provides creative services
                            including manga production, character design, 3D
                            art, and visual development. This Privacy Policy
                            explains how I collect, use, and protect your
                            information when you interact with my website or
                            services.
                        </p>

                        <h3>Information I Collect</h3>
                        <p>
                            I may collect the following types of information
                            when you use my website or contact me:
                        </p>
                        <ul>
                            <li>
                                <strong>Contact form submissions</strong> — Your name,
                                email address, and message content when you use my
                                contact or commission inquiry form.
                            </li>
                            <li>
                                <strong>Email communication</strong> — Information
                                you share through direct email correspondence with
                                me at xyro.art17@gmail.com.
                            </li>
                            <li>
                                <strong>Commission inquiries</strong> — Project descriptions,
                                reference materials, creative briefs, and any files
                                you upload or share during the commission process.
                            </li>
                            <li>
                                <strong>Project information</strong> — Details about
                                your project including scope, timelines, and feedback
                                shared during my collaboration.
                            </li>
                        </ul>

                        <h3>How I Use Your Information</h3>
                        <p>I use the information I collect to:</p>
                        <ul>
                            <li>
                                Respond to your inquiries and commission
                                requests.
                            </li>
                            <li>
                                Provide, manage, and deliver creative services
                                you have requested.
                            </li>
                            <li>
                                Communicate project updates, quotes, and
                                delivery milestones.
                            </li>
                            <li>
                                Improve my website and the quality of my
                                services.
                            </li>
                        </ul>
                        <p>
                            I do not sell, rent, or share your personal
                            information with third parties for marketing
                            purposes.
                        </p>

                        <h3>How Data Is Stored</h3>
                        <p>
                            Xyro is a brand for my freelance creative services. I
                            do not maintain large-scale personal databases.
                            Information you provide is stored securely using the
                            following infrastructure:
                        </p>
                        <ul>
                            <li>
                                Contact form submissions are delivered directly
                                to my email inbox.
                            </li>
                            <li>
                                Project files and communication are stored in
                                secure, password-protected cloud services.
                            </li>
                            <li>
                                My website content is managed through Sanity
                                CMS, which stores only publicly displayed
                                portfolio content — not your personal data.
                            </li>
                        </ul>

                        <h3>Third-Party Services</h3>
                        <p>
                            My website relies on the following third-party
                            services:
                        </p>
                        <ul>
                            <li>
                                <strong>Cloudflare</strong> — Provides CDN, DNS, and
                                security services. Cloudflare may process request
                                metadata (IP address, browser information) for performance
                                and security purposes. See <a
                                    href="https://www.cloudflare.com/privacypolicy/"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    >Cloudflare's Privacy Policy</a
                                >.
                            </li>
                            <li>
                                <strong>Sanity CMS</strong> — My content management
                                system for portfolio content. Sanity does not store
                                visitor data. See <a
                                    href="https://www.sanity.io/legal/privacy"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    >Sanity's Privacy Policy</a
                                >.
                            </li>
                            <li>
                                <strong>Website hosting</strong> — My site is hosted
                                on modern web infrastructure with HTTPS encryption
                                on all pages.
                            </li>
                        </ul>

                        <h3>Cookies</h3>
                        <p>
                            My website uses minimal cookies. I do not use
                            advertising or tracking cookies. Essential cookies
                            may be set by my hosting provider or CDN
                            (Cloudflare) for security and performance purposes.
                            These are necessary for the website to function and
                            cannot be disabled.
                        </p>

                        <h3>Security</h3>
                        <p>
                            I take reasonable measures to protect your
                            information from unauthorized access, disclosure, or
                            destruction. All pages on my website are served
                            over HTTPS. Project files shared during commissions
                            are stored in secure, access-controlled environments
                            and are deleted upon project completion unless
                            otherwise agreed upon.
                        </p>

                        <h3>Your Rights</h3>
                        <p>You have the right to:</p>
                        <ul>
                            <li>
                                Request access to any personal information I
                                hold about you.
                            </li>
                            <li>
                                Request correction of inaccurate information.
                            </li>
                            <li>
                                Request deletion of your personal data from my
                                records.
                            </li>
                            <li>
                                Withdraw consent for future communications at
                                any time.
                            </li>
                        </ul>
                        <p>
                            To exercise any of these rights, please contact me
                            at
                            <a href="mailto:xyro.art17@gmail.com"
                                >xyro.art17@gmail.com</a
                            >. I will respond to all data requests within 30
                            days.
                        </p>

                        <h3>Changes to This Policy</h3>
                        <p>
                            I may update this Privacy Policy from time to time.
                            Changes will be reflected on this page with an
                            updated "Last updated" date. I encourage you to
                            review this page periodically.
                        </p>

                        <h3>Contact</h3>
                        <p>
                            If you have questions about this Privacy Policy or
                            your data, please reach out:
                        </p>
                        <a
                            href="mailto:xyro.art17@gmail.com"
                            class="legal-contact-email"
                        >
                            ✉ xyro.art17@gmail.com
                        </a>
                    </LegalSection>

                    <!-- ============================================== -->
                    <!-- TERMS OF SERVICE                                -->
                    <!-- ============================================== -->
                    <LegalSection id="terms" title="Terms of Service">
                        <p>
                            These Terms of Service ("Terms") govern your use of
                            the Xyro website and any creative services
                            provided by Xyro. By accessing my website or
                            engaging my services, you agree to these Terms.
                        </p>

                        <h3>Scope of Services</h3>
                        <p>
                            I offer independent creative services including, but 
                            not limited to: manga production, character design, 
                            3D art and modeling, visual development, concept art, 
                            illustration, and motion design. The specific scope of 
                            any project is defined through individual commission 
                            agreements between me and the client.
                        </p>

                        <h3>Commission Process</h3>
                        <p>
                            All projects begin with a commission inquiry
                            submitted through my contact form, email, or
                            approved communication channels. Upon receiving your
                            inquiry:
                        </p>
                        <ul>
                            <li>
                                <strong>Quote</strong> — I will review your project
                                details and provide a custom quote including scope,
                                timeline estimate, and pricing.
                            </li>
                            <li>
                                <strong>Acceptance</strong> — A project is considered
                                accepted only after both parties agree on the scope,
                                pricing, and timeline in writing (email confirmation
                                is sufficient).
                            </li>
                            <li>
                                <strong>Timeline estimates</strong> — All timelines
                                are estimates and may vary based on project complexity,
                                revision cycles, and current workload. I will communicate
                                any significant delays promptly.
                            </li>
                        </ul>

                        <h3>Client Responsibilities</h3>
                        <p>
                            To ensure smooth project delivery, clients are
                            expected to:
                        </p>
                        <ul>
                            <li>
                                Provide clear, detailed creative briefs and
                                reference materials at the start of the project.
                            </li>
                            <li>
                                Respond to communications and approval requests
                                in a timely manner.
                            </li>
                            <li>
                                Provide all necessary assets, information, and
                                feedback required for the project.
                            </li>
                            <li>
                                Review and approve deliverables within the
                                agreed revision cycle.
                            </li>
                        </ul>
                        <p>
                            Delays caused by late client responses may impact
                            the project timeline and are not my responsibility.
                        </p>

                        <h3>Intellectual Property</h3>
                        <p>
                            Unless otherwise agreed upon in writing, the
                            following intellectual property terms apply:
                        </p>
                        <ul>
                            <li>
                                Upon full payment, the client receives usage
                                rights to the final delivered artwork for the
                                agreed-upon purpose.
                            </li>
                            <li>
                                I retain the right to display completed
                                work in my portfolio, website, and social media
                                unless a non-disclosure agreement (NDA) is in
                                place.
                            </li>
                            <li>
                                Source files (e.g., PSD, Blender, project files)
                                are not included by default and may be available
                                for an additional fee if agreed upon before
                                project start.
                            </li>
                            <li>
                                Unauthorized reproduction, resale, or
                                redistribution of artwork without permission is
                                prohibited.
                            </li>
                        </ul>

                        <h3>Payment</h3>
                        <p>
                            Payment terms are agreed upon before project
                            commencement. Standard terms include:
                        </p>
                        <ul>
                            <li>
                                A deposit (typically 30–50%) is required before
                                work begins on most projects.
                            </li>
                            <li>
                                The remaining balance is due upon delivery of
                                the final artwork.
                            </li>
                            <li>
                                Payment methods and currency will be agreed upon
                                during the quote process.
                            </li>
                            <li>
                                All prices quoted are exclusive of any
                                applicable taxes unless stated otherwise.
                            </li>
                        </ul>

                        <h3>Revisions</h3>
                        <p>
                            Each project includes a reasonable number of
                            revisions as outlined in the project agreement
                            (typically 2–3 rounds). Additional revisions beyond
                            the agreed scope may incur extra charges, which will
                            be communicated before any additional work begins.
                        </p>
                        <p>
                            Major scope changes requested after production has
                            begun (e.g., complete redesign, significant concept
                            changes) may be treated as a new project or require
                            an adjusted quote.
                        </p>

                        <h3>Cancellation & Refunds</h3>
                        <ul>
                            <li>
                                <strong>Client cancellation</strong> — If you cancel
                                a project after work has begun, you are responsible
                                for payment for all work completed up to the cancellation
                                date. Deposits are non-refundable once production
                                has started.
                            </li>
                            <li>
                                <strong>My cancellation</strong> — In the unlikely
                                event that I cancel a project, I will refund
                                any payments for undelivered work in full.
                            </li>
                            <li>
                                <strong>Refund eligibility</strong> — Refunds are
                                evaluated on a case-by-case basis. Completed and delivered
                                work is not eligible for refund.
                            </li>
                        </ul>

                        <h3>Delivery</h3>
                        <p>
                            Final deliverables are provided in standard digital
                            formats (PNG, JPEG, PDF, or other formats agreed
                            upon). Files are delivered via email, cloud storage
                            link, or other agreed-upon methods. It is the
                            client's responsibility to download and securely
                            store delivered files. I retain backup
                            copies for a reasonable period but am not
                            responsible for long-term archival storage.
                        </p>

                        <h3>Limitation of Liability</h3>
                        <p>
                            I provide creative services on an "as
                            agreed" basis. I am not liable for any indirect,
                            incidental, or consequential damages arising from
                            the use of my services or deliverables. My total
                            liability for any claim related to a project shall
                            not exceed the total amount paid by the client for
                            that specific project.
                        </p>

                        <h3>Governing Law</h3>
                        <p>
                            These Terms are governed by applicable laws. Any
                            disputes arising from these Terms or my services
                            will be resolved through good-faith negotiation
                            between both parties.
                        </p>

                        <h3>Changes to These Terms</h3>
                        <p>
                            I reserve the right to update these Terms at any
                            time. Changes take effect upon posting to this page.
                            Continued use of my website or services after
                            changes constitutes acceptance of the revised Terms.
                        </p>

                        <h3>Contact</h3>
                        <p>
                            For questions about these Terms of Service, please
                            contact me:
                        </p>
                        <a
                            href="mailto:xyro.art17@gmail.com"
                            class="legal-contact-email"
                        >
                            ✉ xyro.art17@gmail.com
                        </a>
                    </LegalSection>

                    <!-- ============================================== -->
                    <!-- COMMISSION GUIDE                                -->
                    <!-- ============================================== -->
                    <LegalSection id="commissions" title="Commission Guide">
                        <p>
                            Working with me is straightforward. Whether
                            you need character designs, manga pages, 3D renders,
                            or concept art — here's exactly how the process
                            works from start to finish.
                        </p>

                        <h3>How It Works</h3>
                        <div class="legal-steps">
                            <div class="legal-step">
                                <div class="legal-step-number">01</div>
                                <div class="legal-step-content">
                                    <h4>Tell me your idea</h4>
                                    <p>
                                        Reach out through my contact form,
                                        email, or Discord with a description of
                                        your project. The more detail you
                                        provide, the faster I can get started.
                                    </p>
                                </div>
                            </div>
                            <div class="legal-step">
                                <div class="legal-step-number">02</div>
                                <div class="legal-step-content">
                                    <h4>Receive a quote</h4>
                                    <p>
                                        I'll review your request and send you a
                                        detailed quote with pricing, timeline
                                        estimate, and scope breakdown — usually
                                        within 24–48 hours.
                                    </p>
                                </div>
                            </div>
                            <div class="legal-step">
                                <div class="legal-step-number">03</div>
                                <div class="legal-step-content">
                                    <h4>Approve the concept</h4>
                                    <p>
                                        Once we agree on terms, I'll begin with
                                        initial concepts or sketches for your
                                        approval before moving to full
                                        production.
                                    </p>
                                </div>
                            </div>
                            <div class="legal-step">
                                <div class="legal-step-number">04</div>
                                <div class="legal-step-content">
                                    <h4>Production begins</h4>
                                    <p>
                                        After concept approval, I dive into
                                        full production. You'll receive progress
                                        updates at key milestones.
                                    </p>
                                </div>
                            </div>
                            <div class="legal-step">
                                <div class="legal-step-number">05</div>
                                <div class="legal-step-content">
                                    <h4>Review & revisions</h4>
                                    <p>
                                        You'll review the work and provide
                                        feedback. Each project includes 2–3
                                        revision rounds to make sure everything
                                        is exactly right.
                                    </p>
                                </div>
                            </div>
                            <div class="legal-step">
                                <div class="legal-step-number">06</div>
                                <div class="legal-step-content">
                                    <h4>Final delivery</h4>
                                    <p>
                                        Once approved, I deliver the final
                                        files in your preferred format. Payment
                                        for the remaining balance is due at this
                                        stage.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <h3>What to Expect</h3>
                        <div class="legal-info-grid">
                            <div class="legal-info-card">
                                <h4>Response Time</h4>
                                <p>
                                    I typically respond to new inquiries within
                                    24–48 hours. During busy periods, it may
                                    take slightly longer — but I always reply.
                                </p>
                            </div>
                            <div class="legal-info-card">
                                <h4>Project Timeline</h4>
                                <p>
                                    Delivery time depends on project complexity.
                                    Simple character designs may take 1–2 weeks,
                                    while larger projects like manga chapters
                                    may take several weeks.
                                </p>
                            </div>
                            <div class="legal-info-card">
                                <h4>Revisions</h4>
                                <p>
                                    Each project includes 2–3 rounds of
                                    revisions. Major scope changes after
                                    production starts may require an updated
                                    quote.
                                </p>
                            </div>
                            <div class="legal-info-card">
                                <h4>Delivery Format</h4>
                                <p>
                                    Final files are delivered in high-resolution
                                    digital formats (PNG, JPEG, PDF). Source
                                    files are available upon request for an
                                    additional fee.
                                </p>
                            </div>
                        </div>

                        <h3>Communication Channels</h3>
                        <p>
                            You can reach me through any of the following:
                        </p>
                        <ul>
                            <li>
                                <strong>Email</strong> — <a
                                    href="mailto:xyro.art17@gmail.com"
                                    >xyro.art17@gmail.com</a
                                > (preferred for formal inquiries)
                            </li>
                            <li>
                                <strong>Discord</strong> — xyro.3d (great for quick
                                questions and project updates)
                            </li>
                            <li>
                                <strong>Instagram</strong> — <a
                                    href="https://www.instagram.com/xyro.3d/"
                                    target="_blank"
                                    rel="noopener noreferrer">xyro.3d</a
                                > (DMs welcome for initial inquiries)
                            </li>
                        </ul>
                        <p>
                            For active projects, we'll agree on a primary
                            communication channel that works best for both
                            sides.
                        </p>

                        <h3>What You'll Receive</h3>
                        <ul>
                            <li>
                                High-resolution final artwork in agreed-upon
                                formats.
                            </li>
                            <li>
                                Progress updates at key milestones throughout
                                the project.
                            </li>
                            <li>
                                Clear communication about timelines, revisions,
                                and any changes.
                            </li>
                            <li>
                                A professional, collaborative experience from
                                start to finish.
                            </li>
                        </ul>

                        <h3>How to Prepare</h3>
                        <p>
                            Before reaching out, it helps to have the following
                            ready:
                        </p>
                        <ul>
                            <li>
                                A clear description of what you need (character
                                design, manga pages, illustration, etc.).
                            </li>
                            <li>
                                Reference images or mood boards for the style or
                                look you're going for.
                            </li>
                            <li>
                                Any specific requirements (dimensions, format,
                                deadline).
                            </li>
                            <li>Your budget range, if you have one in mind.</li>
                        </ul>
                        <p>
                            Don't worry if you don't have everything figured out
                            — I'm happy to help shape the idea with you.
                        </p>

                        <h3>Frequently Asked Questions</h3>
                        <div class="legal-faq">
                            <div class="legal-faq-item">
                                <button
                                    class="legal-faq-question"
                                    aria-expanded="false"
                                >
                                    <span>How much does a commission cost?</span>
                                    <svg
                                        class="legal-faq-icon"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <line x1="12" y1="5" x2="12" y2="19"
                                        ></line>
                                        <line x1="5" y1="12" x2="19" y2="12"
                                        ></line>
                                    </svg>
                                </button>
                                <div class="legal-faq-answer">
                                    <p>
                                        Pricing varies depending on the type of
                                        project, complexity, and scope. I
                                        provide custom quotes for every inquiry
                                        — just reach out with your idea and
                                        I'll give you a clear breakdown.
                                    </p>
                                </div>
                            </div>
                            <div class="legal-faq-item">
                                <button
                                    class="legal-faq-question"
                                    aria-expanded="false"
                                >
                                    <span>Do you take rush orders?</span>
                                    <svg
                                        class="legal-faq-icon"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <line x1="12" y1="5" x2="12" y2="19"
                                        ></line>
                                        <line x1="5" y1="12" x2="19" y2="12"
                                        ></line>
                                    </svg>
                                </button>
                                <div class="legal-faq-answer">
                                    <p>
                                        In some cases, yes. Rush orders are
                                        subject to availability and may incur an
                                        additional fee. Let me know your
                                        deadline when you reach out and I'll do
                                        my best to accommodate.
                                    </p>
                                </div>
                            </div>
                            <div class="legal-faq-item">
                                <button
                                    class="legal-faq-question"
                                    aria-expanded="false"
                                >
                                    <span>Can I use the artwork commercially?</span>
                                    <svg
                                        class="legal-faq-icon"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <line x1="12" y1="5" x2="12" y2="19"
                                        ></line>
                                        <line x1="5" y1="12" x2="19" y2="12"
                                        ></line>
                                    </svg>
